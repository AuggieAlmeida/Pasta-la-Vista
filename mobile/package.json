{
  "name": "pasta-la-vista-mobile",
  "version": "0.1.0",
  "description": "Mobile app para Pasta la Vista - Delivery de comida",
  "main": "expo-app.json",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "eas build --platform android --profile preview",
    "build:prod": "eas build --platform android --profile production",
    "publish": "eas submit",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "delivery",
    "food",
    "mobile",
    "expo",
    "react-native"
  ],
  "author": "Augusto Almeida",
  "license": "MIT",
  "dependencies": {
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/drawer": "^6.6.6",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "@stripe/stripe-react-native": "^9.4.0",
    "@tanstack/react-query": "^5.28.0",
    "axios": "^1.6.5",
    "dotenv": "^16.3.1",
    "expo": "^50.0.0",
    "expo-constants": "^14.4.4",
    "expo-router": "^2.0.0",
    "expo-secure-store": "^12.3.1",
    "expo-splash-screen": "^0.26.5",
    "react": "^18.2.0",
    "react-hook-form": "^7.51.0",
    "react-native": "^0.73.1",
    "react-native-gesture-handler": "^2.14.0",
    "react-native-mmkv-storage": "^0.4.0",
    "react-native-reanimated": "^3.6.0",
    "react-native-safe-area-context": "^4.7.2",
    "react-native-screens": "^3.28.0",
    "zustand": "^4.4.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@babel/core": "^7.23.6",
    "@eslint/js": "^8.55.0",
    "@react-native-community/eslint-plugin": "^1.3.0",
    "@testing-library/react-native": "^12.4.0",
    "@types/jest": "^29.5.11",
    "@types/react": "^18.2.45",
    "@types/react-native": "^0.72.8",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "babel-preset-expo": "^10.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-expo": "^0.0.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "typescript": "^5.3.3"
  }
