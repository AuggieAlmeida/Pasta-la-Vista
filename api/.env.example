# Environment
NODE_ENV=development
PORT=3333

# Database - PostgreSQL (Supabase)
DATABASE_URL=postgresql://user:password@host:5432/pastalavista_dev

# Database - MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/pastalavista_dev

# Cache - Redis (Upstash)
REDIS_URL=redis://:password@host:port

# Authentication
JWT_SECRET=your-super-secret-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=pastalavista
R2_PUBLIC_URL=https://your-bucket.your-domain.com

# Email (opcional, para notificações)
EMAIL_SERVICE=gmail
EMAIL_USER=noreply@example.com
EMAIL_PASSWORD=your-app-password

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:8081,http://localhost:3000
